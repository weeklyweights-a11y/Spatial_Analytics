DB_PASSWORD=changeme
# Optional: override pytest DB password (defaults to DB_PASSWORD from .env, else testpass for CI)
# TEST_DB_PASSWORD=changeme
JWT_SECRET=changeme-generate-a-real-secret-at-least-32-chars
GCS_BUCKET=spatialscore-data
FAISS_INDEX_PATH=/app/data/faiss/faiss_index.bin
EMBEDDING_MAP_PATH=/app/data/faiss/embedding_map.json
MODELS_DIR=/app/models
LOG_LEVEL=INFO
JWT_EXPIRY_HOURS=24
FACE_SIMILARITY_THRESHOLD=0.5
DUPLICATE_REGISTRATION_THRESHOLD=0.6
CORS_ORIGINS=http://localhost:3000,https://spatialscore.buildathon.co
SCORING_FLUSH_INTERVAL=60
HEATMAP_SNAPSHOT_INTERVAL=300
MAX_REGISTRATION_STATIONS=10
VITE_API_URL=http://localhost:8000

# Phase 2 camera workers
CONFIGS_DIR=/app/configs
WORKER_DATABASE_URL=postgresql://spatialscore:changeme@postgres:5432/spatialscore
DEIMV2_CONFIDENCE_THRESHOLD=0.3
FACE_RECOGNITION_INTERVAL_FRAMES=20
CAMERA_TARGET_FPS=10
CAMERA_HEARTBEAT_SECONDS=10
UNIDENTIFIED_TIMEOUT_SECONDS=10
CAMERA_FRAME_TTL_SECONDS=5
